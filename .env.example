# ─── Firebase Configuration ────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → General → Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Site Configuration ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=NexCart

# ─── Google Places API (Module 05 — Smart Address Autocomplete) ───────────────
# Optional — leave blank to use manual address entry fallback
# Get key from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
